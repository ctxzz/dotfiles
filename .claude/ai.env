# 1Password secret references for the AI image skills.
#
# These are *references*, not secrets — safe to commit. They contain only the
# vault / item / field NAMES; the actual API keys stay in your 1Password vault
# and are injected at runtime by `op run --env-file=.claude/ai.env -- ...`.
#
# Recommended (least privilege, per 1Password best practices):
#   - Keep these API keys in a DEDICATED vault (here: "AI") that holds nothing
#     else, so a leaked/abused read is limited to just these keys.
#   - For interactive local use, authenticate with the 1Password app integration
#     (biometric unlock) — no service-account token written to disk.
#     https://developer.1password.com/docs/cli/about-biometric-unlock/
#   - Service accounts are for unattended automation; if you use one, scope it to
#     the AI vault only and never store its token in plaintext.
#
# Edit the op:// paths to match your vault / item / field. Find the exact
# reference with:  op item get "Gemini API" --vault AI --format json
# or copy it from the 1Password app: field -> "Copy Secret Reference".
#
# Format: op://<vault>/<item>/<field>

GEMINI_API_KEY="op://AI/Gemini API/credential"
OPENROUTER_API_KEY="op://AI/OpenRouter/credential"
